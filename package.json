{
  "name": "skill-contract-lab",
  "version": "0.1.0",
  "description": "Local-first operational contract checks for SKILL.md files.",
  "type": "module",
  "bin": {
    "skill-contract": "./bin/skill-contract.js"
  },
  "scripts": {
    "check": "node --check bin/skill-contract.js && node --check src/index.js",
    "test": "node --test",
    "smoke": "node bin/skill-contract.js fixtures/good-skill/SKILL.md --format markdown",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm run test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agents",
    "skills",
    "lint",
    "contract",
    "markdown"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "fixtures",
    "scripts",
    "SKILL.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skill-contract-lab.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skill-contract-lab/issues"
  },
  "homepage": "https://github.com/rogerchappel/skill-contract-lab#readme"
}
